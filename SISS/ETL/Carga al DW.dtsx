    <DTS:Executable
      DTS:refId="Package\carga de dummys"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{C0ACCEA9-C6EC-4FB0-96FD-22BB06408728}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="carga de dummys"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D31C7A25-BD94-49A6-B6B9-440831041B77}"
          SQLTask:SqlStatementSource="SET IDENTITY_INSERT Dim_cliente ON;&#xA;&#xA;INSERT INTO Dim_cliente (sk_cliente, Id_cliente, Nombre_cliente, Tipo_cliente)&#xA;VALUES (-1, -1, 'Cliente Desconocido', 'Desconocido');&#xA;&#xA;SET IDENTITY_INSERT Dim_cliente OFF;&#xA;&#xA;-- Apagamos la protección para inyectar un ID manual en Empleados&#xA;SET IDENTITY_INSERT Dim_empleado ON;&#xA;&#xA;INSERT INTO Dim_empleado (sk_empleado, Id_empleado, Nombre_empleado)&#xA;VALUES (-1, -1, 'Empleado Desconocido');&#xA;&#xA;SET IDENTITY_INSERT Dim_empleado OFF;&#xA;&#xA;INSERT INTO Dim_Calendario (sk_fecha, Dia, Mes, Año, Nombre_dia, Nombre_mes)&#xA;VALUES ('1900-01-01', 1, 1, 1900, 'Desconocido', 'Desconocido');" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Cargado_Fac_ventas"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{55397C01-E5A2-408D-A9AF-3F04E8C7A1B0}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Cargado_Fac_ventas"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D31C7A25-BD94-49A6-B6B9-440831041B77}"
          SQLTask:SqlStatementSource="INSERT INTO Fac_venta (&#xA;    SK_Cliente,&#xA;    SK_Empleado,&#xA;    SK_Producto,&#xA;    sk_fecha_venta,&#xA;    sk_grupo_etario,&#xA;    Nro_factura,&#xA;    Region,&#xA;    Edad_cliente,&#xA;    Edad_empleado,&#xA;    Antiguedad_empleado,&#xA;&#xA;    Sistema_origen,&#xA;    Cantidad_producto,&#xA;    Litros_totales,&#xA;    Precio_individual,&#xA;    Precio_final,&#xA;    Descuento,&#xA;    Precio_final_descuento&#xA;)&#xA;SELECT &#xA;    -- 1. LAS TRADUCCIONES DE CLAVES (Las SK robadas de las dimensiones)&#xA;    ISNULL(dc.sk_cliente, -1) AS sk_cliente,&#xA;    ISNULL(de.sk_empleado, -1) AS sk_empleado,&#xA;    dp.sk_producto,&#xA;    &#xA;    -- 2. LAS CLAVES DIRECTAS (No necesitan JOIN)&#xA;    ISNULL(f.FechaVenta, '1900-01-01') AS sk_fecha_venta,      -- Tu fecha ya es la SK de la dimensión tiempo&#xA;    f.id_rango_etario_cliente, -- El ID que inventaste pasa directo&#xA;    f.billing_id,&#xA;    f.region,&#xA;    ISNULL(f.EdadClienteAlComprar, 0) AS EdadClienteAlComprar,&#xA;    ISNULL(f.EdadEmpleadoAlVender, 0) AS EdadEmpleadoAlVender,&#xA;    ISNULL(f.AntiguedadEmpleadoAlVender, 0) AS AntiguedadEmpleadoAlVender,&#xA;&#xA;    -- 3. LAS MÉTRICAS (Los números puros)&#xA;    f.sis_origen,                   -- Atributo de origen&#xA;    f.CantidadVendida,&#xA;    f.LitrosTotalesLinea,&#xA;    f.PrecioUnitarioHistorico,&#xA;    f.MontoBrutoLinea,&#xA;    f.PorcentajeDescuentoAplicado,&#xA;    f.MontoNetoFinalLinea&#xA;&#xA;FROM vw_L4_Fact_Billings_Final f&#xA;&#xA;-- 4. LOS MÚLTIPLES JOINS PARA ATRAPAR LAS SK&#xA;-- (Cruzamos el ID original del staging con el ID original guardado en la dimensión física)&#xA;&#xA;LEFT JOIN Dim_cliente dc &#xA;    ON f.customer_id = dc.Id_cliente&#xA;&#xA;LEFT JOIN Dim_empleado de &#xA;    ON f.employee_id = de.Id_empleado&#xA;&#xA;OUTER APPLY (&#xA;    SELECT TOP 1 sk_producto&#xA;    FROM Dim_producto&#xA;    WHERE &#xA;        Id_producto = f.product_id&#xA;        -- El candado: La versión debe existir desde antes (o el mismo día) de la venta&#xA;        AND Fecha_Desde &lt;= f.FechaVenta &#xA;        &#xA;    -- Ordenamos de mayor a menor fecha para que la versión correcta quede arriba de todo&#xA;    ORDER BY Fecha_Desde DESC&#xA;) dp;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
