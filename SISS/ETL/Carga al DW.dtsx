    <DTS:Executable
      DTS:refId="Package\Carga_dim_clientes"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{357DCADF-C3B6-4164-BD80-E55D88FF9496}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Carga_dim_clientes"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D31C7A25-BD94-49A6-B6B9-440831041B77}"
          SQLTask:SqlStatementSource="INSERT INTO Dim_cliente (&#xA;    Id_cliente, &#xA;    sk_geografia,       -- La clave foránea que apunta a la nueva dimensión&#xA;    Nombre_cliente, &#xA;    Tipo_cliente, &#xA;    Fecha_nacimiento&#xA;)&#xA;SELECT &#xA;    stg.CUSTOMER_ID,&#xA;    &#xA;    -- ACÁ ESTÁ LA MAGIA: En lugar del zipcode, traemos la SK generada&#xA;    geo.sk_geografia,&#xA;    stg.FULL_NAME,&#xA;    stg.Tipo_cliente,&#xA;    stg.BIRTH_DATE&#xA;&#xA;FROM L4_vw_clientes_final stg&#xA;&#xA;&#xA;LEFT JOIN Dim_geografia geo &#xA;    ON stg.ZIPCODE = geo.Codigo_postal;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Carga_Fac_stock"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarea Ejecutar SQL"
      DTS:DTSID="{0C0E8761-6482-47C4-9319-074C97FE2F67}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Carga_Fac_stock"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D31C7A25-BD94-49A6-B6B9-440831041B77}"
          SQLTask:SqlStatementSource="INSERT INTO Fac_stock(&#xA;    Id_fecha_stock,&#xA;    Id_producto, -- en verdad es el sk,&#xA;    Cantidad&#xA;&#xA;)&#xA;SELECT &#xA;    -- 1. LA FECHA (Como SK directa si usaste DATE)&#xA;    st.Fecha AS SK_Tiempo, &#xA;    &#xA;    -- 2. LA TRADUCCIÓN DE LA SK DE PRODUCTO&#xA;    dp.sk_producto,&#xA;    &#xA;    -- 3. LAS MÉTRICAS DE INVENTARIO&#xA;    st.Cantidad_producto&#xA;    &#xA;FROM vw_stock st&#xA;&#xA;-- 4. EL CRUCE PARA ATRAPAR LA SK&#xA;LEFT JOIN Dim_producto dp &#xA;    ON st.Id_producto = dp.Id_producto;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
